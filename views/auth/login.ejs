    transition: all 0.3s ease;
  }
  
  .input-animated:focus-within {
    transform: translateY(-3px);
  }
  
  .form-control, .input-group-text {
    border-color: #e0e0e0;
    background-color: rgba(255, 255, 255, 0.8);
    transition: all 0.3s ease;
    height: 50px;
  }
  
  .form-control:focus {
