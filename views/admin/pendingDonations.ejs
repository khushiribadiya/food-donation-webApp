<main>
    <%- include('../partials/adminSidebar') %>
    
    <div id="main-wrapper">
        <div class="bg-white shadow-sm p-3">
            <span class="me-3" id="sidebar-toggler-btn"><i class="fas fa-bars"></i></span>
            <h5 class="m-0 color-theme d-inline-block">Pending Donations</h5>
        </div>
        
        <div class="container-fluid my-4">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">Donation Requests</h5>
                        <span class="badge bg-light text-primary"><%= pendingDonations.length %> pending</span>
                    </div>
                </div>
                
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover m-0">
                            <thead class="table-light">
                                <tr>
                                    <th scope="col">#</th>
                                    <th scope="col">Donor Name</th>
                                    <th scope="col">Food Type</th>
                                    <th scope="col">Quantity</th>
                                    <th scope="col">Date & Time</th>
                                    <th scope="col">Location</th>
                                    <th scope="col">Status</th>
                                    <th scope="col">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if(pendingDonations.length > 0) { %>
                                    <% for(let i=0; i<pendingDonations.length; i++) { %>
                                        <tr>
                                            <th scope="row"><%= i+1 %></th>
                                            <td><%= pendingDonations[i].donor.firstName + " " + pendingDonations[i].donor.lastName %></td>
                                            <td><%= pendingDonations[i].foodType %></td>
                                            <td><%= pendingDonations[i].quantity %></td>
                                            <td>
                                                <% if(pendingDonations[i].cookingTime) { %>
                                                    <%= pendingDonations[i].cookingTime.toLocaleString("en-IN", { dateStyle: "short", timeStyle: "short"}) %>
                                                <% } else { %>
                                                    Not specified
                                                <% } %>
                                            </td>
                                            <td>
                                                <% if(pendingDonations[i].address) { %>
                                                    <% const addressParts = pendingDonations[i].address.split(',') %>
                                                    <%= addressParts[addressParts.length-1].trim() %>
                                                <% } else { %>
                                                    Not specified
                                                <% } %>
                                            </td>
                                            <td>
                                                <span class="badge bg-<%= pendingDonations[i].status === 'pending' ? 'warning' : 'primary' %> text-white">
                                                    <%= pendingDonations[i].status %>
                                                </span>
                                            </td>
                                            <td>
                                                <a href="/admin/donation/view/<%= pendingDonations[i]._id %>" class="btn btn-sm btn-outline-primary">
                                                    <i class="fas fa-eye me-1"></i> View
                                                </a>
                                            </td>
                                        </tr>
                                    <% } %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="8" class="text-center py-4">
                                            <div class="p-3">
                                                <i class="fas fa-inbox fa-3x text-muted mb-3"></i>
                                                <p class="mb-0">No pending donations at the moment.</p>
                                            </div>
                                        </td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>