<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Our Mission - Food Aid</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/aos/2.3.4/aos.css" rel="stylesheet">
  <style>
    body {
      margin: 0;
      padding: 0;
      font-family: 'Segoe UI', sans-serif;
      color: #0d2c42;
      background: linear-gradient(to right, #e0f7fa, #f0f4f8);
      overflow-x: hidden;
      position: relative;
    }

    body::before,
    body::after {
      content: '';
      position: absolute;
      width: 300px;
      height: 300px;
      background: radial-gradient(circle, rgba(0,123,255,0.2) 0%, transparent 70%);
      border-radius: 50%;
      z-index: 0;
    }

    body::before {
      top: -100px;
      left: -100px;
    }

    body::after {
      bottom: -100px;
      right: -100px;
    }

    .floating-icon {
      position: absolute;
      font-size: 2rem;
      opacity: 0.1;
      z-index: 0;
      animation: float var(--speed, 6s) ease-in-out infinite;
      transform: translateY(0);
    }

    @keyframes float {
      0%   { transform: translateY(0px) rotate(0deg); }
      50%  { transform: translateY(-20px) rotate(10deg); }
      100% { transform: translateY(0px) rotate(0deg); }
    }

    .container {
      position: relative;
      z-index: 1;
      padding: 2rem;
    }

    .section-title {
      font-size: 2.8rem;
      font-weight: 700;
      text-align: center;
      margin-bottom: 2rem;
      position: relative;
    }

    .section-title::after {
      content: '';
      width: 80px;
      height: 4px;
      background: #007bff;
      position: absolute;
      left: 50%;
      transform: translateX(-50%);
      bottom: -10px;
    }

    .mission-box {
      background-color: #ffffffcc;
      padding: 2rem;
      border-radius: 15px;
      box-shadow: 0 8px 20px rgba(0, 0, 0, 0.1);
      backdrop-filter: blur(10px);
    }

    .mission-icon {
      font-size: 3rem;
      margin-right: 1rem;
      color: #007bff;
    }

    .cta-button {
      margin-top: 1.5rem;
      padding: 10px 25px;
      background: #007bff;
      color: white;
      border: none;
      border-radius: 50px;
      font-weight: bold;
      transition: all 0.3s ease;
      text-decoration: none;
    }

    .cta-button:hover {
      background: #0056b3;
    }

    .stats {
      margin-top: 3rem;
    }

    .stat-box {
      background-color: #ffffffdd;
      border-radius: 12px;
      padding: 1.5rem;
      box-shadow: 0 4px 15px rgba(0,0,0,0.1);
      text-align: center;
      transition: transform 0.3s ease;
    }

    .stat-box:hover {
      transform: translateY(-5px);
    }

    .stat-number {
      font-size: 2rem;
      font-weight: bold;
      color: #007bff;
    }

    .stat-label {
      font-size: 1.1rem;
      margin-top: 0.5rem;
    }
  </style>
</head>
<body>
  <div class="floating-icon" style="top:10%; left:5%; --speed:7s;">🍎</div>
  <div class="floating-icon" style="top:20%; left:80%; --speed:8s;">🍕</div>
  <div class="floating-icon" style="top:65%; left:15%; --speed:6s;">🍛</div>
  <div class="floating-icon" style="top:75%; left:60%; --speed:5s;">🥗</div>
  <div class="floating-icon" style="top:35%; left:40%; --speed:7s;">🍞</div>
  <div class="floating-icon" style="top:50%; left:85%; --speed:6.5s;">🍊</div>
  <div class="floating-icon" style="top:15%; left:20%; --speed:7.2s;">🥑</div>
  <div class="floating-icon" style="top:80%; left:25%; --speed:9s;">🍇</div>
  <div class="floating-icon" style="top:55%; left:70%; --speed:8.5s;">🍔</div>
  <div class="floating-icon" style="top:45%; left:10%; --speed:6.8s;">🧁</div>
  <div class="floating-icon" style="top:25%; left:60%; --speed:7.3s;">🍓</div>
  <div class="floating-icon" style="top:70%; left:45%; --speed:8.2s;">🍍</div>
  <div class="floating-icon" style="top:30%; left:75%; --speed:7.4s;">🌮</div>
  <div class="floating-icon" style="top:60%; left:30%; --speed:6.6s;">🥙</div>
  <div class="floating-icon" style="top:10%; left:90%; --speed:7.7s;">🍜</div>

  <div class="container">
    <h1 class="section-title" data-aos="fade-down">Our Mission</h1>

    <div class="mission-box d-flex flex-column flex-md-row align-items-start" data-aos="fade-up">
      <div class="mission-icon">🍱</div>
      <div>
        <p class="lead">
          Our mission is to combat hunger and reduce food wastage by connecting food
          donors with individuals and communities in need. We aim to create an
          efficient, transparent, and accessible system that ensures surplus food
          reaches the right hands — promoting compassion, sustainability, and social
          responsibility.
        </p>
        <a href="/signup" class="cta-button">Join Us</a>
      </div>
    </div>

    <div class="row stats mt-5" data-aos="fade-up" data-aos-delay="150">
      <div class="col-md-4 mb-3">
        <div class="stat-box">
          <div class="stat-number">10,000+</div>
          <div class="stat-label">Meals Donated</div>
        </div>
      </div>
      <div class="col-md-4 mb-3">
        <div class="stat-box">
          <div class="stat-number">5,000+</div>
          <div class="stat-label">People Helped</div>
        </div>
      </div>
      <div class="col-md-4 mb-3">
        <div class="stat-box">
          <div class="stat-number">50+</div>
          <div class="stat-label">Cities Reached</div>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/aos/2.3.4/aos.js"></script>
  <script>
    AOS.init();
  </script>
</body>
</html>
