<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>About Us</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"/>

  <style>
    html, body {
      margin: 0;
      padding: 0;
      overflow-x: hidden;
      overflow-y: auto;
      height: auto;
      min-height: 100%;
      font-family: 'Segoe UI', sans-serif;
      position: relative;
    }

    .wave-background {
      position: fixed;
      bottom: 0;
      left: 0;
      z-index: -1;
      width: 100%;
      height: 200px;
      pointer-events: none;
    }

    .wave-background svg {
      width: 200%;
      height: auto;
      animation: waveSlide 20s linear infinite;
    }

    @keyframes waveSlide {
      0% { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }

    .crazy-heading {
  font-size: 3.5rem;
  font-weight: bold;
  background: linear-gradient(90deg, #004466, #0077aa, #009ec3);
  background-size: 300% 300%;
  background-clip: text;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  animation: hueRotate 4s ease infinite, bounceIn 1s ease;
  text-align: center;
  margin-top: 2rem;
}


    @keyframes hueRotate {
      0% { background-position: 0% 50%; }
      50% { background-position: 100% 50%; }
      100% { background-position: 0% 50%; }
    }

    @keyframes bounceIn {
      0% { opacity: 0; transform: scale(0.3); }
      50% { opacity: 1; transform: scale(1.05); }
      70% { transform: scale(0.9); }
      100% { transform: scale(1); }
    }

    .fade-in {
      opacity: 0;
      transform: translateY(20px);
      animation: fadeInUp 1s ease forwards;
    }
    .fade-in:nth-child(1) { animation-delay: 0.3s; }
    .fade-in:nth-child(2) { animation-delay: 0.6s; }
    .fade-in:nth-child(3) { animation-delay: 0.9s; }
    .fade-in:nth-child(4) { animation-delay: 1.2s; }

    @keyframes fadeInUp {
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .color-theme {
      color: #004466;
      font-weight: 700;
    }

    .btn-learn {
      margin-top: 20px;
      background: linear-gradient(135deg, #004466, #0077aa);
      color: white;
      transition: all 0.4s ease;
      border: none;
      padding: 10px 24px;
      border-radius: 30px;
      position: relative;
      overflow: hidden;
    }

    .btn-learn .arrow {
      display: inline-block;
      transition: transform 0.4s ease;
      margin-left: 8px;
    }

    .btn-learn.less .arrow {
      transform: rotate(180deg);
    }

    .btn-learn::before {
      content: "";
      position: absolute;
      top: 50%;
      left: 50%;
      width: 300%;
      height: 300%;
      background: rgba(255, 255, 255, 0.1);
      transition: opacity 0.6s, transform 0.6s;
      transform: translate(-50%, -50%) scale(0);
      border-radius: 50%;
      z-index: 0;
    }

    .btn-learn:active::before {
      transform: translate(-50%, -50%) scale(1);
      opacity: 0;
    }

    .btn-learn span {
      position: relative;
      z-index: 1;
    }

    #extraInfo {
      display: none;
    }

    .info-card {
      display: flex;
      gap: 1rem;
      align-items: flex-start;
      background-color: #f7f9fa;
      border-left: 4px solid #0077aa;
      border-radius: 8px;
      padding: 1rem;
      margin-top: 1.5rem;
      animation: slideIn 0.6s ease forwards;
    }

    @keyframes slideIn {
      from {
        transform: translateY(20px);
        opacity: 0;
      }
      to {
        transform: translateY(0);
        opacity: 1;
      }
    }

    .info-card img {
      width: 60px;
      height: 60px;
    }

    @media screen and (max-width: 768px) {
      .crazy-heading {
        font-size: 2.2rem;
      }

      .info-card {
        flex-direction: column;
        align-items: flex-start;
      }

      .info-card img {
        margin-bottom: 10px;
      }
    }
  </style>
</head>

<body>

  <!-- 🌊 Animated Background -->
  <div class="wave-background">
    <svg viewBox="0 0 1440 320">
      <path fill="#b3dbf5" fill-opacity="1" d="M0,64L48,85.3C96,107,192,149,288,160C384,171,480,149,576,144C672,139,768,149,864,154.7C960,160,1056,160,1152,144C1248,128,1344,96,1392,80L1440,64L1440,320L1392,320C1344,320,1248,320,1152,320C1056,320,960,320,864,320C768,320,672,320,576,320C480,320,384,320,288,320C192,320,96,320,48,320L0,320Z"></path>
    </svg>
  </div>

  <!-- 🧠 Heading -->
  <h1 class="crazy-heading">About Us</h1>

  <!-- 💬 Info Section -->
  <div class="bg-white m-4 p-4 shadow rounded">
    <ul class="fs-5">
      <li class="fade-in">We are an online platform dedicated to reducing food waste and helping the needy.</li>
      <li class="fade-in">Our mission is to connect food donors with underprivileged individuals and communities.</li>
      <li class="fade-in">We aim to make the process of donating food simple, secure, and efficient.</li>
      <li class="fade-in">Through collective efforts, we strive to create a hunger-free and compassionate society.</li>
    </ul>

    <!-- 🔁 Learn More Button -->
    <button class="btn btn-learn" onclick="toggleLearnMore(this)">
      <span>Learn More</span>
      <span class="arrow">▼</span>
    </button>

    <!-- 📦 Extra Info -->
    <div id="extraInfo">
      <div class="info-card">
        <img src="https://cdn-icons-png.flaticon.com/512/190/190411.png" alt="Hands Icon">
        <div>
          <h5 class="color-theme">Our Network</h5>
          <p>We collaborate with NGOs, food banks, and volunteers to ensure that surplus food is distributed efficiently and responsibly.</p>
        </div>
      </div>

      <div class="info-card">
        <img src="https://cdn-icons-png.flaticon.com/512/2917/2917242.png" alt="Heart Icon">
        <div>
          <h5 class="color-theme">Your Impact</h5>
          <p>By being a part of our initiative, you're contributing to a sustainable and hunger-free future.</p>
        </div>
      </div>
    </div>
  </div>

  <!-- 🔧 JS Toggle Script -->
  <script>
    function toggleLearnMore(button) {
      const info = document.getElementById('extraInfo');
      const arrow = button.querySelector('.arrow');
      const span = button.querySelector('span');

      if (info.style.display === 'block') {
        info.style.display = 'none';
        button.classList.remove('less');
        span.textContent = 'Learn More';
        arrow.textContent = '▼';
      } else {
        info.style.display = 'block';
        button.classList.add('less');
        span.textContent = 'Less';
        arrow.textContent = '▲';
      }
    }
  </script>

</body>
</html>
