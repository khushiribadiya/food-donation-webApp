<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#3f51b5" />
    
    <!-- Font Awesome -->
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css"
      integrity="sha512-1ycn6IcaQQ40/MKBW2W4Rhis/DbILU74C1vSrLJxCq57o941Ym01SwNsOMqvEBFlcgUa6xLiPY/NS5R+E6ztJQ=="
      crossorigin="anonymous"
      referrerpolicy="no-referrer"
    />
    
    <!-- Bootstrap CSS - Using only ONE version (5.3.0) -->
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-9ndCyUaIbzAi2FUVXJi0CjmCapSmO7SnpJef0486qhLnuZ2cdeRhO02iuK6FUUVM"
      crossorigin="anonymous"
    />
    
    <!-- Custom CSS -->
    <link rel="stylesheet" href="/assets/css/admin-dashboard.css">
    <link rel="stylesheet" href="/assets/css/style.css" />
    <link rel="stylesheet" href="/assets/css/sidebar.css" />
    
    <!-- AOS Animation CSS -->
    <link
      href="https://cdnjs.cloudflare.com/ajax/libs/aos/2.3.4/aos.css"
      rel="stylesheet"
    />

    <!-- Additional navbar style fix -->
    <style>
      /* Make sure navbar collapse shows properly on mobile */
      @media (max-width: 576px) {
        .navbar-collapse.show {
          display: block !important;
        }
        .navbar-collapse {
          position: absolute;
          top: 100%;
          right: 0;
          left: 0;
          background-color: #1a2d4d; 
          padding: 1rem;
          z-index: 1000;
        }
      }
      
      /* styles */
      .contact-title {
        text-align: center;
        margin-top: 2rem;
        margin-bottom: 2rem;
        color: #004080;
        font-weight: bold;
        font-size: 2.5rem;
      }

      .contact-wrapper {
        display: flex;
        justify-content: center;
        flex-wrap: wrap;
        gap: 2rem;
        padding: 0 2rem 4rem;
      }

      .contact-card {
        background: #fff;
        border-radius: 15px;
        padding: 2rem;
        width: 300px;
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.08);
        text-align: center;
        transition: transform 0.3s ease;
      }

      .contact-card:hover {
        transform: translateY(-5px);
      }

      .contact-icon {
        width: 60px;
        height: 60px;
        margin: 0 auto 1rem;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 1.5rem;
      }

      .bg-primary {
        background-color: #007bff;
      }

      .bg-success {
        background-color: #28a745;
      }

      .bg-danger {
        background-color: #dc3545;
      }

      a {
        color: #004080;
        text-decoration: none;
        font-weight: 500;
      }

      a:hover {
        text-decoration: underline;
      }
    </style>

    <title><%= typeof title != 'undefined' ? title : "Meal Share" %></title>
  </head>

  <body>
    <%- include('partials/header') %>
    <%- include('partials/alerts') %>
    <%- body %>

    <!-- Bootstrap JS Bundle - Using only ONE version (5.3.0) -->
    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-geWF76RCwLtnZ8qwWowPQNguL3RmwHVBC9FhGdlKrxdiJJigb/j/68SIy3Te4Bkz"
      crossorigin="anonymous"
    ></script>
    
    <!-- Custom JS -->
    <script src="/assets/js/script.js"></script>
    
    <!-- AOS Animation JS -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/aos/2.3.4/aos.js"></script>
    <script>
      AOS.init();
    </script>
    
    <!-- Completely revised navbar toggle script -->
    <script>
      document.addEventListener('DOMContentLoaded', function() {
        // Get navbar elements
        const navbarToggler = document.querySelector('.navbar-toggler');
        const navbarMenu = document.getElementById('navbarSupportedContent');
        
        if (navbarToggler && navbarMenu) {
          // Remove any existing click handlers (important to prevent conflicts)
          navbarToggler.replaceWith(navbarToggler.cloneNode(true));
          
          // Get the fresh reference after replacement
          const freshToggler = document.querySelector('.navbar-toggler');
          
          // Add our custom toggle handler
          freshToggler.addEventListener('click', function(e) {
            e.preventDefault();
            e.stopPropagation();
            
            if (navbarMenu.classList.contains('show')) {
              navbarMenu.classList.remove('show');
            } else {
              navbarMenu.classList.add('show');
            }
            return false;
          });
          
          // Add click handlers to all nav links to close menu when clicked
          const navLinks = document.querySelectorAll('.nav-link');
          navLinks.forEach(function(link) {
            link.addEventListener('click', function(e) {
              // Only handle closing if we're in mobile view
              if (window.innerWidth < 576) {
                navbarMenu.classList.remove('show');
              }
            });
          });
          
          // Close navbar when clicking elsewhere on the page
          document.body.addEventListener('click', function(e) {
            // Only process if menu is open and click is outside menu and toggle button
            if (navbarMenu.classList.contains('show') && 
                !navbarMenu.contains(e.target) && 
                !freshToggler.contains(e.target)) {
              navbarMenu.classList.remove('show');
            }
          });
        }
      });
    </script>
  </body>
</html>